# ─────────────────────────────────────────────────────────────
#  Charaka Vaidya — Environment Configuration
# ─────────────────────────────────────────────────────────────
#  Get your free Groq API key at: https://console.groq.com
# ─────────────────────────────────────────────────────────────

# ── Groq LLM (REQUIRED) ───────────────────────────────────────
GROQ_API_KEY=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

# ── Model choice (optional — default is llama3-70b-8192) ──────
# Options: llama3-70b-8192 | llama-3.1-8b-instant | mixtral-8x7b-32768 | gemma2-9b-it
LLM_MODEL=llama-3.3-70b-versatile

# ── Embeddings (HuggingFace, free + local, no key needed) ─────
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./data/chroma_db

# ── RAG tuning (optional) ─────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5
PDF_PATH=./data/charaka_samhita.pdf

# ── API server (optional) ─────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:8501
DEBUG=false
